# Recommended default for stock Android TV v9 + Stremio:
# - Real DNS hostname
# - Publicly trusted certificate (Let's Encrypt / ZeroSSL)
# - Reverse proxy to local Node app (127.0.0.1:7010)
#
# PUBLIC_BASE_URL must match this hostname, e.g.:
# PUBLIC_BASE_URL=https://stremio-addarr.example.com
#
# Requirements:
# - `stremio-addarr.example.com` resolves to your Caddy host
# - TCP 80/443 reachable for ACME HTTP challenge
#   (or use DNS challenge if you cannot expose ports)

stremio-addarr.example.com {
    encode zstd gzip
    reverse_proxy 127.0.0.1:7010
}

# ─────────────────────────────────────────────────────────────
# Advanced only (not recommended for stock Android TV):
# Internal CA certificates may not be trusted by Stremio on non-root TV devices.
#
# local-name.lan {
#     tls internal
#     reverse_proxy 127.0.0.1:7010
# }
