# Caddyfile example for stremio-addarr — DuckDNS DNS-01 (no port forwarding)
#
# REQUIREMENTS:
#   - A custom Caddy binary with the DuckDNS DNS provider plugin is required.
#     The standard APT caddy package does NOT include DNS plugins.
#     Download from https://caddyserver.com/download (add github.com/caddy-dns/duckdns)
#     or build with: xcaddy build --with github.com/caddy-dns/duckdns
#
#   - Store your DuckDNS token in /etc/caddy/caddy.env (not here):
#       DUCKDNS_TOKEN=your-token-here
#     and load it via a systemd drop-in EnvironmentFile (see README_HOST.md).
#
# Replace "myaddarr" with your actual DuckDNS subdomain.

myaddarr.duckdns.org {
    # DNS-01 ACME challenge — no router port forwarding required
    tls {
        dns duckdns {env.DUCKDNS_TOKEN}
    }

    encode zstd gzip

    # Stremio derives /<ADDON_ACCESS_TOKEN>/configure from the protected
    # manifest transport URL. This compatibility rewrite also supports v1.6.1.
    @tokenConfigure path_regexp tokenConfigure ^/[A-Za-z0-9_-]{4,128}/configure$
    rewrite @tokenConfigure /configure

    reverse_proxy 127.0.0.1:7010
}
