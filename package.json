{
  "name": "stremio-addarr",
  "version": "1.6.1",
  "private": true,
  "description": "Self-hosted Stremio add-on that shows Arr status and adds movies or series to Radarr/Sonarr.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "check": "npm run typecheck",
    "test": "tsx --test test/*.test.ts",
    "test:catalog": "tsx --test --test-name-pattern=catalog test/catalog.test.ts test/addon.test.ts",
    "test:ci": "tsx --test --test-reporter=spec test/*.test.ts",
    "preci": "python3 .automation/run_final_hardening.py",
    "ci": "python3 .automation/run_final_ci.py",
    "postci": "python3 .automation/final_hardening_finish.py",
    "package:release": "node scripts/package-release.mjs",
    "lint:manifest": "node scripts/lint-manifest.mjs"
  },
  "dependencies": {
    "express": "^5.1.0",
    "stremio-addon-sdk": "^1.6.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "stremio-addon-linter": "github:Stremio/stremio-addon-linter#b791ab42c7ea3781829fe95ed3553bf2b902c3be"
  }
}
