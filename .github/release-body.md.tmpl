Quick Upgrade:

```
gh release download --repo ${REPO} ${TAG} --pattern 'stremio-addarr-install.tar.gz*' --clobber && \
sudo mkdir -p /opt/stremio-addarr && sudo tar -xzf stremio-addarr-install.tar.gz -C /opt/stremio-addarr --strip-components=1; \
export SVC_USER="$(whoami)" && export SVC_GROUP="$(id -gn)" && sudo chown -R "$SVC_USER:$SVC_GROUP" /opt/stremio-addarr; \
cd /opt/stremio-addarr && npm ci --omit=dev; \
icdiff .env.example .env; icdiff deploy/stremio-addarr.service.example /etc/systemd/system/stremio-addarr.service; \
sudo systemctl daemon-reload && sudo systemctl restart stremio-addarr; sleep 3; sudo systemctl is-active stremio-addarr; \
source .env; curl http://127.0.0.1:7010/manifest.json; curl -fI "https://${PUBLIC_BASE_URL}/manifest.json"; \
cat /opt/stremio-addarr/package.json; curl -fsS http://127.0.0.1:7010/healthz; curl -fsS "https://${PUBLIC_BASE_URL}/status.json"; \
echo '' && echo "https://${PUBLIC_BASE_URL}/manifest.json"
```

