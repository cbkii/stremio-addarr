# ── Server (private app behind Caddy) ────────────────
# The app binds to loopback only. It must NOT be exposed directly on the LAN.
# Caddy is the public-facing HTTPS front door (see README_HOST.md).
HOST=127.0.0.1
PORT=7010

# Target-client compatibility profile:
# - android-tv (default): strict checks for stock Android TV constraints.
# - generic: keeps warnings but allows advanced/local certificate setups.
TARGET_CLIENT=android-tv

# REQUIRED: this must exactly match the hostname Caddy serves.
# Format: https://YOUR_HOSTNAME (no trailing slash, no path)
# Example: https://myaddarr.duckdns.org
PUBLIC_BASE_URL=https://replace-with-your-hostname

# JSON log verbosity (debug/info/warn/error/none).
LOG_LEVEL=info
# Optional explicit manifest/app version override (otherwise package.json version is used).
# APP_VERSION=0.1.1
# Timeout for each Arr HTTP request in milliseconds.
REQUEST_TIMEOUT_MS=5000
# Grace period to close HTTP server after SIGTERM/SIGINT before forced exit.
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
# Exit code if graceful shutdown timeout is reached (0=successful stop, 1=failure).
FORCED_SHUTDOWN_EXIT_CODE=0
# TTL for Radarr/Sonarr status list caches in milliseconds.
STATUS_CACHE_TTL_MS=30000
# TTL for cached Arr reachability health checks in milliseconds.
SERVICE_HEALTH_CACHE_TTL_MS=10000
# Stremio cacheMaxAge hint for stream responses in seconds.
STREAM_CACHE_MAX_AGE=2
# Stremio staleRevalidate hint for stream responses in seconds.
STREAM_STALE_REVALIDATE=5
# Catalog response page size (Stremio sends `skip` for next page).
CATALOG_PAGE_SIZE=25
# Short merged catalog cache TTL (milliseconds).
CATALOG_CACHE_TTL_MS=5000
# Stremio cache hints for catalog responses (seconds).
CATALOG_CACHE_MAX_AGE_SEC=15
CATALOG_STALE_REVALIDATE_SEC=60
CATALOG_STALE_ERROR_SEC=120

# ── Radarr ────────────────────────────────────────────
RADARR_ENABLED=true
RADARR_BASE_URL=http://127.0.0.1:7878
RADARR_API_KEY=replace-with-radarr-api-key
# Required when RADARR_ENABLED=true
RADARR_ROOT_FOLDER_PATH=/media/movies
RADARR_QUALITY_PROFILE_ID=1
RADARR_MINIMUM_AVAILABILITY=announced
# Comma-separated Radarr tag IDs (integers) to apply when adding movies.
# Find your tag IDs via Radarr → Settings → Tags, or GET /api/v3/tag.
RADARR_TAGS=
RADARR_SEARCH_ON_ADD=true

# ── Sonarr ────────────────────────────────────────────
SONARR_ENABLED=true
SONARR_BASE_URL=http://127.0.0.1:8989
SONARR_API_KEY=replace-with-sonarr-api-key
# Required when SONARR_ENABLED=true
SONARR_ROOT_FOLDER_PATH=/media/tv
SONARR_QUALITY_PROFILE_ID=1
SONARR_LANGUAGE_PROFILE_ID=1
# SONARR_SERIES_MONITOR maps to Sonarr `addOptions.monitor` when adding a series.
# Valid values: all, future, missing, existing, firstSeason, lastSeason, latestSeason, pilot, recent, monitorSpecials, unmonitorSpecials, none, skip, ep, epfuture, epseason
# Custom values for episode pages:
# - ep       => selected episode only, then set Sonarr monitorNewItems=none
# - epfuture => selected episode + all later episodes, then set monitorNewItems=all
# - epseason => selected episode through end of season, then set monitorNewItems=none
SONARR_SERIES_MONITOR=all
# monitorNewItems policy applied via series editor updates.
# - auto => epfuture=>all, ep/epseason=>none, default non-scoped add=>all
# - all|none => force explicit value regardless of mode
SONARR_MONITOR_NEW_ITEMS=auto
# Max wait/poll tuning while Sonarr materializes episode metadata after add.
SONARR_EPISODE_READY_TIMEOUT_MS=60000
SONARR_EPISODE_READY_POLL_MS=1500
# EP_COUNT behavior for `SONARR_SERIES_MONITOR=ep`:
# - if EP_COUNT <= 1 (or blank), disabled
# - else check up to EP_COUNT_PAST prior episodes and if downloaded count >= EP_COUNT,
#   switch ep mode to EP_COUNT_MOD
EP_COUNT=2
EP_COUNT_PAST=8
EP_COUNT_MOD=epfuture
SONARR_SEARCH_ON_ADD=true
# Comma-separated Sonarr tag IDs (integers) to apply when adding series.
# Find your tag IDs via Sonarr → Settings → Tags, or GET /api/v3/tag.
SONARR_TAGS=

# ── Kodi integration (optional) ──────────────────────────────────────────────
# When enabled, downloaded tiles that lack a direct playback URL include a Kodi
# launch link via Android intent so the user can open Kodi from Stremio.
# KODI_ENABLED=true
# KODI_PACKAGE=org.xbmc.kodi

# ── Pi file streaming (optional, disabled by default) ────────────────────────
# When enabled, "downloaded" tiles in Stremio include a direct HTTP playback URL
# so you can watch files already on the Pi without launching Kodi.
#
# Requirements:
#   - PUBLIC_BASE_URL must be HTTPS (already required for Android TV).
#   - Caddy proxies /files/* to this app — no extra Caddyfile changes needed.
#   - Files are served raw (no transcoding). Stremio's native player handles
#     H.264/H.265/VP9 MKV/MP4 on Android TV.
#
# FILE_STREAMING_ENABLED=false
# FILE_STREAMING_SECRET=replace-with-a-long-random-secret  # 32+ chars, required when enabled
# FILE_STREAMING_PLAYBACK_MODE=direct  # direct|kodi (default: direct when streaming enabled, otherwise kodi)
