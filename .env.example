# ─── Server ─────────────────────────────────────────────────────────────────
# Bind address for the Node process (0.0.0.0 = all interfaces)
HOST=0.0.0.0
# Port the addon listens on (Caddy will proxy HTTPS → this port)
PORT=7010
# The HTTPS URL that Stremio clients use to reach this addon.
# Must be HTTPS for remote Stremio clients (Android TV, mobile, etc.).
# Use Caddy or another reverse proxy to terminate TLS.
# Example: https://stremio-addarr.lan  (internal CA via Caddy)
# For local desktop testing only: http://127.0.0.1:7010
PUBLIC_BASE_URL=https://stremio-addarr.lan
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=5000
STATUS_CACHE_TTL_MS=30000
# Set to true to show a confirm page before adding to Arr (optional safeguard)
ACTION_CONFIRM=false

# ─── Radarr ─────────────────────────────────────────────────────────────────
RADARR_ENABLED=true
# When Radarr runs on the same Pi: http://127.0.0.1:7878
# When Radarr is on another LAN host: http://192.168.1.20:7878
RADARR_BASE_URL=http://127.0.0.1:7878
RADARR_API_KEY=your-radarr-api-key-here
RADARR_ROOT_FOLDER_PATH=/data/media/movies
RADARR_QUALITY_PROFILE_ID=1
RADARR_MINIMUM_AVAILABILITY=announced
RADARR_TAGS=
RADARR_SEARCH_ON_ADD=true

# ─── Sonarr ─────────────────────────────────────────────────────────────────
SONARR_ENABLED=true
# When Sonarr runs on the same Pi: http://127.0.0.1:8989
# When Sonarr is on another LAN host: http://192.168.1.21:8989
SONARR_BASE_URL=http://127.0.0.1:8989
SONARR_API_KEY=your-sonarr-api-key-here
SONARR_ROOT_FOLDER_PATH=/data/media/tv
SONARR_QUALITY_PROFILE_ID=1
SONARR_LANGUAGE_PROFILE_ID=1
SONARR_SERIES_MONITOR=all
SONARR_SEARCH_ON_ADD=true
SONARR_TAGS=

# ─── Optional ───────────────────────────────────────────────────────────────
# TMDB API key for fallback movie/series lookup (not required).
TMDB_API_KEY=
