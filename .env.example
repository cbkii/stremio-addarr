# Server
PORT=7010
HOST=0.0.0.0
PUBLIC_BASE_URL=https://stremio-addarr.lan
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=5000
STATUS_CACHE_TTL_MS=30000
# true = show confirmation page before side-effect add request
ACTION_CONFIRM=false

# Radarr
RADARR_ENABLED=true
RADARR_BASE_URL=http://192.168.1.20:7878
RADARR_API_KEY=replace-me
RADARR_ROOT_FOLDER_PATH=/data/media/movies
RADARR_QUALITY_PROFILE_ID=1
RADARR_MINIMUM_AVAILABILITY=announced
RADARR_TAGS=stremio-addarr
RADARR_SEARCH_ON_ADD=true

# Sonarr
SONARR_ENABLED=true
SONARR_BASE_URL=http://192.168.1.21:8989
SONARR_API_KEY=replace-me
SONARR_ROOT_FOLDER_PATH=/data/media/tv
SONARR_QUALITY_PROFILE_ID=1
SONARR_LANGUAGE_PROFILE_ID=1
SONARR_SERIES_MONITOR=all
SONARR_SEARCH_ON_ADD=true
SONARR_TAGS=stremio-addarr

# Optional TMDB fallback for stronger movie/series lookup later.
TMDB_API_KEY=
