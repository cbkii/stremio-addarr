# ── Server (private app behind Caddy) ────────────────
# The app binds to loopback only. It must NOT be exposed directly on the LAN.
# Caddy is the public-facing HTTPS front door (see README_HOST.md).
HOST=127.0.0.1
PORT=7010

# Target-client compatibility profile:
# - android-tv (default): strict checks for stock Android TV constraints.
# - generic: keeps warnings but allows advanced/local certificate setups.
TARGET_CLIENT=android-tv

# Public URL that Stremio clients use to reach the add-on.
# Must be the exact HTTPS origin: https://HOSTNAME  (no trailing slash, no path)
# Set this to your DuckDNS hostname (or whichever hostname Caddy serves).
# Example: PUBLIC_BASE_URL=https://myaddarr.duckdns.org
# Not recommended for stock Android TV:
#   - http://...
#   - https://192.168.x.x
#   - https://*.local / *.lan
PUBLIC_BASE_URL=https://stremio-addarr.example.com

# JSON log verbosity (debug/info/warn/error).
LOG_LEVEL=info
# Timeout for each Arr HTTP request in milliseconds.
REQUEST_TIMEOUT_MS=5000
# TTL for Radarr/Sonarr status list caches in milliseconds.
STATUS_CACHE_TTL_MS=30000
# TTL for cached Arr reachability health checks in milliseconds.
SERVICE_HEALTH_CACHE_TTL_MS=10000
# Stremio cacheMaxAge hint for stream responses in seconds.
STREAM_CACHE_MAX_AGE=2
# Stremio staleRevalidate hint for stream responses in seconds.
STREAM_STALE_REVALIDATE=5

# ── Radarr ────────────────────────────────────────────
# Radarr running on the same Pi:
RADARR_ENABLED=true
RADARR_BASE_URL=http://127.0.0.1:7878
RADARR_API_KEY=your-radarr-api-key-here
# Required when RADARR_ENABLED=true
RADARR_ROOT_FOLDER_PATH=/media/movies
RADARR_QUALITY_PROFILE_ID=1
RADARR_MINIMUM_AVAILABILITY=announced
RADARR_TAGS=
RADARR_SEARCH_ON_ADD=true

# If Radarr is on another LAN host:
# RADARR_BASE_URL=http://192.168.1.50:7878

# ── Sonarr ────────────────────────────────────────────
# Sonarr running on the same Pi:
SONARR_ENABLED=true
SONARR_BASE_URL=http://127.0.0.1:8989
SONARR_API_KEY=your-sonarr-api-key-here
# Required when SONARR_ENABLED=true
SONARR_ROOT_FOLDER_PATH=/media/tv
SONARR_QUALITY_PROFILE_ID=1
SONARR_LANGUAGE_PROFILE_ID=1
# MONITOR options: all, future, missing, unaired, none
SONARR_SERIES_MONITOR=all
SONARR_SEARCH_ON_ADD=true
SONARR_TAGS=

# ── Optional ──────────────────────────────────────────
# TMDB_API_KEY=
