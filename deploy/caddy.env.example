# Caddy environment file — /etc/caddy/caddy.env
#
# Store DNS provider credentials here rather than in the Caddyfile.
# This file must be owned root:caddy with mode 600:
#
#   sudo install -m 600 -o root -g caddy /dev/null /etc/caddy/caddy.env
#   sudo nano /etc/caddy/caddy.env
#
# Load this file in the Caddy systemd service by creating a drop-in:
#
#   sudo mkdir -p /etc/systemd/system/caddy.service.d
#   sudo tee /etc/systemd/system/caddy.service.d/env.conf > /dev/null << 'EOF'
#   [Service]
#   EnvironmentFile=/etc/caddy/caddy.env
#   EOF
#   sudo systemctl daemon-reload && sudo systemctl restart caddy
#
# See README_HOST.md Step 3 for full instructions.

# ── DuckDNS ──────────────────────────────────────────
# Token from https://www.duckdns.org (shown at top of dashboard after sign-in)
DUCKDNS_TOKEN=your-duckdns-token-here

# ── deSEC (only for existing dedyn.io users or bring-your-own-domain) ────────
# Token from https://desec.io (Token Management in the dashboard)
# DESEC_TOKEN=your-desec-token-here
