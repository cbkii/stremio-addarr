# /etc/caddy/caddy.env
# Canonical env-file path used by README_HOST.md and caddy.service.
# Keep this file root-only.

# Create/update commands:
#   sudo install -m 600 -o root -g root /dev/null /etc/caddy/caddy.env
#   sudo nano /etc/caddy/caddy.env
#   sudo systemctl restart caddy

# DuckDNS API token from https://www.duckdns.org dashboard
DUCKDNS_TOKEN=replace-with-your-real-duckdns-token
