# Caddyfile example for stremio-addarr (DuckDNS DNS-01)
# Requires a custom Caddy binary with github.com/caddy-dns/duckdns.
# Stock `apt install caddy` does not include this plugin.
# Canonical env file: /etc/caddy/caddy.env
# Required variable in that env file:
#   DUCKDNS_TOKEN=replace-with-your-real-duckdns-token

# REQUIRED: replace the hostname below with your real DuckDNS hostname.
# This hostname must match PUBLIC_BASE_URL in /opt/stremio-addarr/.env.
replace-with-your-subdomain.duckdns.org {
    tls {
        dns duckdns {env.DUCKDNS_TOKEN}
    }

    encode zstd gzip
    reverse_proxy 127.0.0.1:7010
}
